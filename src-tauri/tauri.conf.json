{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ludo",
  "version": "0.1.0",
  "identifier": "com.codleed.ludo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ludo",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "signCommand": {
        "cmd": "C:\\Program Files (x86)\\Windows Kits\\10\\bin\\10.0.26100.0\\x64\\signtool.exe",
        "args": [
          "sign",
          "/sha1",
          "470C7C45F726BFFA230A26112B893103043949BE",
          "/fd",
          "sha256",
          "%1"
        ]
      }
    }
  }
}
